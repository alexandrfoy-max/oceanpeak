<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Luxury Yachts Collection</title>
<style>
body{margin:0;font-family:Arial,Helvetica,sans-serif;background:#0b0f14;color:white}
header{padding:30px;text-align:center}
.logo{height:60px;display:block;margin:0 auto 15px auto}
.title{font-size:40px;letter-spacing:3px}
.yachts{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:30px;padding:40px}
.card{background:#141a22;border-radius:20px;overflow:hidden;box-shadow:0 20px 40px rgba(0,0,0,0.4);transition:0.3s}
.card:hover{transform:translateY(-10px)}
.card img{width:100%;height:220px;object-fit:cover}
.card-content{padding:25px}
.name{font-size:26px;margin-bottom:10px}
.price{opacity:0.7;margin-bottom:20px}
button{padding:12px 20px;border:none;border-radius:30px;background:#d4af37;color:black;font-weight:bold;cursor:pointer}
footer{text-align:center;padding:30px;opacity:0.5}
</style>
</head>
<body>

<header>
<img class="logo" src="logo.png" alt="Company Logo">
<div class="title">Private Luxury Yacht Charters</div>
<div>Tenerife • Canary Islands</div>
</header>

<section class="yachts">

<div class="card">
<img src="https://images.unsplash.com/photo-1567899378494-47b22a2ae96a">
<div class="card-content">
<div class="name">Lady Sunshine</div>
<div class="price">From €6,500 / day</div>
<button>Book Private Charter</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1500375592092-40eb2168fd21">
<div class="card-content">
<div class="name">Champagne</div>
<div class="price">Up to 8 guests</div>
<div class="price">3h €500 • 4h €650 • 6h €950</div>
<button>Book Private Charter</button>
</div>
</div>

<div class="card">
<img src="https://images.unsplash.com/photo-1500375592092-40eb2168fd21">
<div class="card-content">
<div class="name">Armani</div>
<div class="price">Up to 6 guests</div>
<div class="price">3h €400 • 4h €500 • 6h €850</div>
<button>Book Private Charter</button>
</div>
</div>

</section>

<footer>
Private Yacht Charters • Tenerife & Canary Islands
</footer>

</body>
</html>
